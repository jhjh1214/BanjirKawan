# --- Database (Railway Postgres, or local docker-compose postgres) ---
# Local dev (docker-compose maps the container to host port 5433):
DATABASE_URL=postgres://banjir:banjir@localhost:5433/banjirkawan

# --- Telegram (create a bot with @BotFather) ---
# Optional at boot: without it the webhook route replies 503 and sends are skipped (logged).
TELEGRAM_BOT_TOKEN=
# Any random string; must match the secret_token you register the webhook with.
TELEGRAM_WEBHOOK_SECRET=

# --- Gemini (Google AI Studio, free tier) — used from Day 2 (onboarding vision) ---
GEMINI_API_KEY=
# gemini-2.5-flash is retired for new keys; 3.5-flash verified working 2026-07-13
GEMINI_MODEL=gemini-3.5-flash
# Per-model free-tier quotas are independent; on 503/429 the client falls through in order
GEMINI_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-flash-lite-latest

# --- InfoBanjir polling ---
# All of Malaysia. Trim the list for lighter dev polling (e.g. SEL,WLH).
INFOBANJIR_STATE_CODES=PLS,KDH,PNG,PRK,SEL,WLH,PTJ,NSN,MLK,JHR,PHG,TRG,KEL,SRK,SAB,WLP
# 60s is comfortable for 16 states (fetched 4 at a time); 30s works for a few states.
POLL_INTERVAL_SECONDS=60

# --- App ---
# Public base URL of the deployed web service (used for Telegram webhook registration)
APP_BASE_URL=http://localhost:3000
# Where onboarding photos are stored (Railway volume mount path in prod)
UPLOADS_DIR=./data/uploads
NODE_ENV=development
